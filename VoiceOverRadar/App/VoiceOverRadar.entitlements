<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      The App Sandbox forbids reading OTHER apps' accessibility trees, so this
      tool must ship NON-sandboxed (Developer ID, outside the Mac App Store).
    -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
